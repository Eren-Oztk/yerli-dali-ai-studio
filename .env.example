# ─────────────────────────────────────────────────────────
#  Yerli Dali AI Studio — Konfigürasyon Şablonu
#
#  KURULUM:
#    1. Bu dosyayı kopyala: cp .env.example .env
#    2. .env dosyasını düzenle (gerçek değerleri yaz)
#    3. .env dosyasını asla Git'e ekleme! (.gitignore'da var)
# ─────────────────────────────────────────────────────────

# ── Telegram (zorunlu)
# Telegram'dan al: https://t.me/BotFather → /newbot
TELEGRAM_TOKEN=BURAYA_BOTFATHER_TOKENINI_YAZ

# Telegram ID'ni bul: https://t.me/userinfobot
ADMIN_ID=BURAYA_KENDI_TELEGRAM_ID_YAZI

# ── Klasörler
# Real-ESRGAN exe ve modellerin bulunduğu ana klasör
BASE_DIR=D:/YerliDali

# Çıktı ve temp klasörleri (boş bırakırsan BASE_DIR altına otomatik oluşturulur)
# OUT_DIR=D:/YerliDali/out
# TEMP_DIR=D:/YerliDali/temp

# ── Motor yolları (boş bırakırsan BASE_DIR altında arar)
# ESRGAN_EXE_PATH=D:/YerliDali/realesrgan-ncnn-vulkan.exe
# GFPGAN_MODEL_PATH=D:/YerliDali/gfpgan/weights/GFPGANv1.4.pth

# ── İşlem ayarları
TILE_SIZE=512                  # 128 / 256 / 512 / 1024
DEFAULT_SCALE=4
DEFAULT_GRAIN=0.10             # 0.0 (kapalı) — 0.30 (belirgin)
DEFAULT_GFPGAN=true
MAX_QUEUE_SIZE=50
WORKER_TIMEOUT=300             # saniye

# ── Gradio
GRADIO_HOST=127.0.0.1
GRADIO_PORT=7860

# ── Güvenlik
MAX_IMAGE_MB=50.0
